# ==========================================
# CONFIGURAÇÃO DE BANCO DE DADOS
# ==========================================
# Crie um arquivo .env na raiz do projeto (15_06_2026/)
# com a seguinte variável preenchida com seus dados

# Opção 1: Neon (PostgreSQL em nuvem)
# DATABASE_URL=postgresql://seu_usuario:sua_senha@seu_host/seu_banco

# Opção 2: PostgreSQL Local
# DATABASE_URL=postgresql://postgres:sua_senha@localhost:5432/roteiro13

# Opção 3: Docker PostgreSQL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roteiro13
